generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  Indica
  Hybrid
  Sativa
}

model Product {
  id            String              @id @default(cuid())
  name          String
  slug          String              @unique
  salePrice     Decimal             @db.Decimal(10, 2)
  originalPrice Decimal             @db.Decimal(10, 2)
  image         String
  category      Category
  thc           String
  popularity    Int                 @default(0)
  featured      Boolean             @default(false)
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  variants      Variant[]
  collections   ProductCollection[]
  wishlists     Wishlist[]
  reviews       Review[]

  @@index([category])
  @@index([popularity])
  @@index([isActive])
}

model Variant {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  weight        String
  price         Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  discount      String?
  sortOrder     Int      @default(0)

  @@index([productId])
}

model Collection {
  id       String              @id @default(cuid())
  name     String              @unique
  label    String
  products ProductCollection[]
}

model ProductCollection {
  productId    String
  collectionId String
  sortOrder    Int        @default(0)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@index([collectionId])
}

// ── Auth + Orders (Phase 2) ──

enum UserRole {
  user
  admin
}

enum OrderStatus {
  processing
  shipped
  in_transit
  delivered
  cancelled
}

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String   @unique
  hashedPassword String
  phone          String?
  role           UserRole @default(user)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  orders         Order[]
  wishlists      Wishlist[]
  addresses      SavedAddress[]
  reviews        Review[]
}

model Order {
  id             String      @id @default(cuid())
  orderNumber    String      @unique
  userId         String?
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  status         OrderStatus @default(processing)
  subtotal       Decimal     @db.Decimal(10, 2)
  shippingCost   Decimal     @db.Decimal(10, 2)
  total          Decimal     @db.Decimal(10, 2)
  firstName      String
  lastName       String
  country        String
  street1        String
  street2        String?
  city           String
  province       String
  postalCode     String
  phone          String
  email          String
  paymentMethod  String
  notes          String?
  trackingNumber String?
  carrierName    String?
  items          OrderItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([userId])
  @@index([orderNumber])
  @@index([email])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String?
  productName  String
  productImage String
  weight       String
  unitPrice    Decimal @db.Decimal(10, 2)
  quantity     Int

  @@index([orderId])
}

// ── Wishlist + Addresses (Phase 3) ──

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model SavedAddress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  isDefault Boolean  @default(false)
  firstName String
  lastName  String
  street    String
  apartment String?
  city      String
  state     String
  zip       String
  country   String   @default("Canada")
  phone     String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── Coupons + Settings (Phase 5 – Admin) ──

enum DiscountType {
  percentage
  fixed
}

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  minOrder      Decimal?     @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int          @default(0)
  isActive      Boolean      @default(true)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([code])
  @@index([isActive])
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  label String @default("")

  @@index([key])
}

// ── Reviews (Phase 4) ──

model Review {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName String
  rating       Int      // 1-5
  title        String?
  text         String
  verified     Boolean  @default(false)
  helpfulCount Int      @default(0)
  photoUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([productId])
  @@index([userId])
}
