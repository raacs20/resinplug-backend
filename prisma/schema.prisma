generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  Indica
  Hybrid
  Sativa
}

model Product {
  id              String              @id @default(cuid())
  name            String
  slug            String              @unique
  salePrice       Decimal             @db.Decimal(10, 2)
  originalPrice   Decimal             @db.Decimal(10, 2)
  image           String
  category        Category
  thc             String
  popularity      Int                 @default(0)
  featured        Boolean             @default(false)
  isActive        Boolean             @default(true)
  // New fields
  description     String?             @db.Text
  shortDesc       String?
  sku             String?
  totalStockGrams Decimal?            @db.Decimal(10, 2)
  stockUnit       String              @default("grams")
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  // Timestamps
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  // Relations
  variants        Variant[]
  images          ProductImage[]
  collections     ProductCollection[]
  wishlists       Wishlist[]
  reviews         Review[]
  stockMovements  StockMovement[]
  reorderPoint    Int?            @default(0)
  relatedProductIds String[]        @default([])

  @@index([category])
  @@index([popularity])
  @@index([isActive])
}

model Variant {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  weight        String
  price         Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  discount      String?
  sortOrder     Int      @default(0)
  // New fields
  sku           String?
  gramsPerUnit  Decimal? @db.Decimal(10, 2)
  stockOverride Int?
  isActive      Boolean  @default(true)

  @@index([productId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([productId])
}

model Collection {
  id       String              @id @default(cuid())
  name     String              @unique
  label    String
  products ProductCollection[]
}

model ProductCollection {
  productId    String
  collectionId String
  sortOrder    Int        @default(0)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@index([collectionId])
}

// ── Auth + Orders ──

enum UserRole {
  user
  admin
}

enum OrderStatus {
  processing
  shipped
  in_transit
  delivered
  cancelled
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String         @unique
  hashedPassword String
  phone          String?
  isBanned       Boolean        @default(false)
  role           UserRole       @default(user)
  creditBalance  Decimal        @db.Decimal(10, 2) @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  orders         Order[]
  wishlists      Wishlist[]
  addresses      SavedAddress[]
  reviews        Review[]
  credits        Credit[]
  notes          CustomerNote[]
}

model Order {
  id             String      @id @default(cuid())
  orderNumber    String      @unique
  userId         String?
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  status         OrderStatus @default(processing)
  subtotal       Decimal     @db.Decimal(10, 2)
  shippingCost   Decimal     @db.Decimal(10, 2)
  total          Decimal     @db.Decimal(10, 2)
  firstName      String
  lastName       String
  country        String
  street1        String
  street2        String?
  city           String
  province       String
  postalCode     String
  phone          String
  email          String
  paymentMethod  String
  notes          String?
  trackingNumber String?
  carrierName    String?
  // New fields
  discountAmount Decimal?    @db.Decimal(10, 2)
  couponCode     String?
  creditsUsed    Decimal?    @db.Decimal(10, 2)
  items          OrderItem[]
  events         OrderEvent[]
  refunds        Refund[]
  orderNotes     OrderNote[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([userId])
  @@index([orderNumber])
  @@index([email])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String?
  productName  String
  productImage String
  weight       String
  unitPrice    Decimal @db.Decimal(10, 2)
  quantity     Int
  review       Review? // Reverse relation: one review per order-item

  @@index([orderId])
}

// ── Wishlist + Addresses ──

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model SavedAddress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  isDefault Boolean  @default(false)
  firstName String
  lastName  String
  street    String
  apartment String?
  city      String
  state     String
  zip       String
  country   String   @default("Canada")
  phone     String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── Coupons + Settings ──

enum DiscountType {
  percentage
  fixed
}

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  minOrder      Decimal?     @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int          @default(0)
  isActive      Boolean      @default(true)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([code])
  @@index([isActive])
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  label String @default("")

  @@index([key])
}

// ── Reviews ──

model Review {
  id           String     @id @default(cuid())
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  orderItemId  String?    @unique // Ties review to a specific order-item purchase
  orderItem    OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  customerName String
  rating       Int
  title        String?
  text         String
  verified     Boolean    @default(false)
  helpfulCount Int        @default(0)
  photoUrl     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([productId])
  @@index([userId])
}

// ── Credits / Rewards ──

enum CreditType {
  earned
  spent
  refund
  manual
}

model Credit {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Decimal    @db.Decimal(10, 2)
  type      CreditType
  reason    String?
  orderId   String?
  createdAt DateTime   @default(now())

  @@index([userId])
  @@index([orderId])
}

// ── Page SEO ──

model PageSeo {
  id              String   @id @default(cuid())
  pageSlug        String   @unique
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogImage         String?
  updatedAt       DateTime @updatedAt

  @@index([pageSlug])
}

// ── Activity Log ──

model ActivityLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  entity    String
  entityId  String?
  details   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([entity])
  @@index([createdAt])
}

// ── Discounts / Marketing ──

model Discount {
  id        String       @id @default(cuid())
  name      String
  type      DiscountType
  value     Decimal      @db.Decimal(10, 2)
  appliesTo String       @default("all")
  targetIds String?
  startDate DateTime?
  endDate   DateTime?
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

// ── CMS Content ──

model ContentBlock {
  id        String   @id @default(cuid())
  key       String   @unique
  type      String   @default("text")
  value     String   @db.Text
  section   String
  label     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([section])
}

// ── Notifications ──

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
}

// ── Customer Notes ──

model CustomerNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note      String   @db.Text
  createdBy String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── Order Events / Timeline ──

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      String   // "status_change", "tracking_added", "note_added", "refund_issued", "created"
  fromValue String?  // e.g. old status
  toValue   String?  // e.g. new status
  note      String?  @db.Text
  adminId   String?
  adminName String?
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

model Refund {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(10, 2)
  reason      String   // "customer_request", "defective", "wrong_item", "duplicate", "other"
  notes       String?  @db.Text
  status      String   @default("completed") // "pending", "completed", "failed"
  processedBy String?
  createdAt   DateTime @default(now())

  @@index([orderId])
}

model OrderNote {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  note      String   @db.Text
  isInternal Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())

  @@index([orderId])
}

// -- FAQ --

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -- Analytics Events --

model AnalyticsEvent {
  id          String   @id @default(cuid())
  event       String   // "page_view", "view_item", "add_to_cart", "begin_checkout", "purchase"
  url         String?
  pageTitle   String?
  productId   String?
  productName String?
  category    String?
  value       Float?
  sessionId   String
  userId      String?
  userAgent   String?
  referrer    String?
  metadata    String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([event, createdAt])
  @@index([sessionId])
  @@index([createdAt])
}

// -- Stock Movements --

model StockMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String   // adjustment, order_deduction, order_restore, restock
  quantity  Float    // positive = added, negative = removed
  reason    String?
  reference String?  // order ID or admin note
  adminName String?
  createdAt DateTime @default(now())

  @@index([productId])
}
